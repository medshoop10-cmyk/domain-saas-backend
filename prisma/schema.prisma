generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  ELITE
}

enum AlertType {
  price_drop
  availability
  score_change
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  incomplete
  incomplete_expired
  trialing
  unpaid
  paused
}

model User {
  id                   String     @id @default(uuid())
  email                String     @unique
  passwordHash         String
  name                 String?
  plan                 Plan       @default(FREE)
  stripeCustomerId     String?
  searchCount          Int        @default(0)
  alertCount           Int        @default(0)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  favorites     Favorite[]
  alerts        Alert[]
  searchHistory SearchHistory[]
  subscriptions Subscription[]
  usage         Usage[]
  clicks        Click[]
  feedback      Feedback[]
  registrarVotes RegistrarVote[]
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(incomplete)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSubscriptionId])
  @@index([status])
}

model Domain {
  id          String   @id @default(uuid())
  name        String   @unique
  tld         String
  length      Int
  score       Float    @default(0)
  isBrandable Boolean  @default(false)
  hasKeywords Boolean  @default(false)
  backlinks   Int      @default(0)
  source           String   @default("wordlist")
  price            Float?
  traffic          Int?
  expiryDate       DateTime?
  keywords         String?
  opportunityScore Int      @default(0)
  bucket           String   @default("standard")
  googleResults    Int      @default(0)
  velocityScore    Int      @default(0)
  confidenceScore  Int      @default(0)
  liquidityScore   Int      @default(0)
  domainType       String   @default("generated")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  favorites      Favorite[]
  alerts         Alert[]
  clicks        Click[]
  feedback      Feedback[]
  trendingDomain TrendingDomain?

  @@index([tld, score(sort: Desc)])
  @@index([isBrandable, score(sort: Desc)])
  @@index([tld, isBrandable, score(sort: Desc)])
  @@index([length, score(sort: Desc)])
  @@index([score(sort: Desc), id])
  @@index([createdAt(sort: Desc)])
  @@index([name])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  domainId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([userId, domainId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([domainId, createdAt(sort: Desc)])
}

model Alert {
  id        String    @id @default(uuid())
  userId    String
  domainId  String
  type      AlertType @default(price_drop)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([domainId, type])
}

model SearchHistory {
  id        String   @id @default(uuid())
  userId    String
  query     String
  filters   Json?
  results   Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model Usage {
  id             String   @id @default(uuid())
  userId         String
  date           String   // YYYY-MM-DD
  searchesCount  Int      @default(0)
  alertsCount    Int      @default(0)
  favoritesCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Click {
  id        String   @id @default(uuid())
  domainId  String
  registrar String
  position  String?
  variant   String?
  userId    String?
  createdAt DateTime @default(now())

  domain Domain  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([domainId, createdAt(sort: Desc)])
  @@index([registrar])
  @@index([createdAt(sort: Desc)])
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String?
  domainId  String
  score     Int      // 1 = thumbs up, -1 = thumbs down
  query     String?
  createdAt DateTime @default(now())

  domain Domain  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([userId, domainId])
  @@index([domainId])
  @@index([userId])
}

model RegistrarVote {
  id        String   @id @default(uuid())
  userId    String?
  registrar String
  score     Int      // 1 = upvote, -1 = downvote
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([userId, registrar])
  @@index([registrar])
  @@index([userId])
}

model TrendingDomain {
  id        String   @id @default(uuid())
  domainId  String   @unique
  score     Float    @default(0)
  searches  Int      @default(0)
  saves     Int      @default(0)
  rank      Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([rank])
  @@index([score(sort: Desc), rank])
}
